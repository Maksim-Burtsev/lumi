# ==========================================================
# Lumi local MVP configuration
# Copy to .env and fill in the secrets marked below.
# ==========================================================

APP_ENV=local
APP_NAME=Lumi
# Public HTTPS URL for the Telegram Mini App (e.g. cloudflared/ngrok tunnel).
# Leave empty until you have a tunnel; the bot will tell you what to do.
APP_PUBLIC_URL=
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_PUBLIC_PATH=/app
DEFAULT_TIMEZONE=Europe/Moscow

# Generate with: python -m lumi.scripts.generate_secret_key
APP_SECRET_KEY=change-me-local-secret
# Generate with: python -m lumi.scripts.generate_encryption_key
ENCRYPTION_KEY=change-me-fernet-key
# Optional standalone web login. Generate with: openssl rand -hex 32
WEB_SESSION_SECRET=

# ==========================================================
# Database / Redis (defaults work with docker compose as-is)
# ==========================================================
DATABASE_URL=postgresql+asyncpg://lumi:lumi@postgres:5432/lumi
POSTGRES_DB=lumi
POSTGRES_USER=lumi
POSTGRES_PASSWORD=lumi
REDIS_URL=redis://redis:6379/0

# ==========================================================
# Telegram  <-- REQUIRED
# ==========================================================
# From @BotFather
TELEGRAM_BOT_TOKEN=
# Your Telegram numeric user id (comma-separated if several).
# Get it from @userinfobot, or send /start to the bot and check `make logs`.
ALLOWED_TELEGRAM_USER_IDS=
LOG_UNAUTHORIZED_TELEGRAM_IDS=true
# Prod ingress: webhook. Local default: polling.
TELEGRAM_WEBHOOK_ENABLED=false
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_CHAT_DEBOUNCE_MS=1200
TELEGRAM_TURN_LOCK_SECONDS=300
TELEGRAM_TURN_MAX_RETRIES=3
TELEGRAM_TURN_RETRY_BASE_SECONDS=10
TELEGRAM_MAX_QUEUE_PER_USER=25
# Bot API 10.1 rich messages are still unsupported by Telegram Web. Keep false for prod.
TELEGRAM_USE_RICH_MESSAGES=false
# Stream final LLM replies by editing the Telegram status message in safe chunks.
TELEGRAM_STREAM_FINAL_REPLIES=true
TELEGRAM_STREAM_EDIT_INTERVAL_SECONDS=0.75
TELEGRAM_STREAM_MIN_CHARS=24
TELEGRAM_STREAM_MAX_CHARS=3900
# Keep Telegram visibly alive while MiniMax/planner is still working.
TELEGRAM_PROGRESS_HEARTBEAT_ENABLED=true
TELEGRAM_PROGRESS_HEARTBEAT_INTERVAL_SECONDS=3.0
TELEGRAM_CHAT_ACTION_INTERVAL_SECONDS=4.0
TELEGRAM_PROGRESS_STALE_AFTER_SECONDS=12.0
TELEGRAM_PROGRESS_LONG_AFTER_SECONDS=30.0
WORKER_MAX_JOBS=10

# ==========================================================
# LLM  <-- REQUIRED for real AI (mock works without a key)
# ==========================================================
# "minimax" for the real model, "mock" for local smoke tests without a key
LLM_PROVIDER=minimax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M3
LLM_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=3
LLM_CONTEXT_MAX_CHARS=120000
STORE_LLM_DEBUG_PAYLOADS=false

# Context / compaction tuning
RECENT_MESSAGES_LIMIT=30
COMPACT_AFTER_MESSAGES=80
COMPACT_AFTER_CHARS=160000
SUMMARY_TARGET_CHARS=12000

# ==========================================================
# Google connector (optional — Lumi works without it)
# ==========================================================
GOOGLE_OAUTH_CLIENT_SECRET_FILE=/app/data/secrets/google_client_secret.json
GOOGLE_OAUTH_TOKEN_FILE=/app/data/secrets/google_token.json
GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar.readonly,https://www.googleapis.com/auth/calendar.events
CALENDAR_SYNC_DAYS_AHEAD=90
CALENDAR_SYNC_DAYS_BACK=1

# ==========================================================
# Scheduler
# ==========================================================
SCHEDULER_TICK_SECONDS=30
SCHEDULER_LOCK_SECONDS=300

# ==========================================================
# Local dev only (keep disabled unless you know why)
# ==========================================================
DEV_AUTH_ENABLED=false
DEV_AUTH_TELEGRAM_USER_ID=
AUTO_MIGRATE=false
